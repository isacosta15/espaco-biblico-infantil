# Copie este arquivo para .env (uso local) e/ou configure as mesmas
# variáveis em Vercel > Project Settings > Environment Variables.

# String de conexão do Postgres (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Segredo usado para assinar os tokens JWT. Gere um valor aleatório forte,
# por exemplo com: openssl rand -base64 48
JWT_SECRET=troque-por-um-valor-aleatorio-bem-grande

# Opcional - só usado pelo script de seed do admin (scripts/src/seed-admin.ts)
SEED_ADMIN_EMAIL=admin@ebi.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrador
